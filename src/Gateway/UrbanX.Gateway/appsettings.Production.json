{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "${CORS_ALLOWED_ORIGINS}"
  },
  "OpenTelemetry": {
    "ServiceName": "UrbanX.Gateway"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_COLLECTOR_ENDPOINT}",
  "IdentityServer": {
    "Authority": "${IDENTITY_SERVER_URL}",
    "Audience": "urbanx-api"
  }
}
