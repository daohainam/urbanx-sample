@page "/categories"
@attribute [Authorize(Roles = "admin")]

<PageTitle>Categories - UrbanX Admin</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentStack Orientation="Orientation.Horizontal">
        <FluentLabel Typo="Typography.H2">Categories Management</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" 

                      OnClick="@ShowAddDialog">
            Add Category
        </FluentButton>
    </FluentStack>

    <FluentCard>
        <FluentSearch @bind-Value="_searchTerm" 
                      Placeholder="Search categories..." 
                      @oninput="OnSearchInput"
                      Style="width: 300px;" />
    </FluentCard>

    <FluentDataGrid Items="@FilteredCategories" Pagination="@_pagination" Style="width: 100%;">
        <PropertyColumn Property="@(c => c.Name)" Title="Name" Sortable="true" />
        <PropertyColumn Property="@(c => c.Description)" Title="Description" />
        <PropertyColumn Property="@(c => c.ProductCount)" Title="Products" Sortable="true" />
        <TemplateColumn Title="Status">
            @if (context.IsActive)
            {
                <FluentBadge Fill="somevalue" BackgroundColor="var(--success)" Color="var(--neutral-foreground-on-accent)">Active</FluentBadge>
            }
            else
            {
                <FluentBadge Fill="somevalue" BackgroundColor="var(--error)" Color="var(--neutral-foreground-on-accent)">Inactive</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                <FluentButton Appearance="Appearance.Lightweight" 

                              OnClick="@(() => EditCategory(context))">
                    Edit
                </FluentButton>
                <FluentButton Appearance="Appearance.Lightweight" 

                              OnClick="@(() => DeleteCategory(context))">
                    Delete
                </FluentButton>
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>

    <FluentPaginator State="@_pagination" />
</FluentStack>

@code {
    private List<CategoryModel> _categories = new();
    private string _searchTerm = string.Empty;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        _categories = new List<CategoryModel>
        {
            new() { Id = Guid.NewGuid(), Name = "Electronics", Description = "Electronic devices and accessories", ProductCount = 150, IsActive = true },
            new() { Id = Guid.NewGuid(), Name = "Clothing", Description = "Fashion and apparel", ProductCount = 320, IsActive = true },
            new() { Id = Guid.NewGuid(), Name = "Books", Description = "Books and literature", ProductCount = 89, IsActive = true },
            new() { Id = Guid.NewGuid(), Name = "Sports", Description = "Sports equipment and gear", ProductCount = 75, IsActive = true },
            new() { Id = Guid.NewGuid(), Name = "Home & Garden", Description = "Home decor and gardening", ProductCount = 210, IsActive = true },
        };
        await Task.CompletedTask;
    }

    private IQueryable<CategoryModel> FilteredCategories
    {
        get
        {
            var filtered = _categories.AsQueryable();
            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                filtered = filtered.Where(c => 
                    c.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrEmpty(c.Description) && c.Description.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)));
            }
            return filtered;
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
    }

    private void ShowAddDialog()
    {
        // TODO: Show add category dialog
    }

    private void EditCategory(CategoryModel category)
    {
        // TODO: Show edit dialog
    }

    private async Task DeleteCategory(CategoryModel category)
    {
        _categories.Remove(category);
        await Task.CompletedTask;
    }

    public class CategoryModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int ProductCount { get; set; }
        public bool IsActive { get; set; }
    }
}
