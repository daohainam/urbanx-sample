{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "paymentdb": "${DATABASE_CONNECTION_STRING}"
  },
  "OpenTelemetry": {
    "ServiceName": "UrbanX.Payment.Service"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_COLLECTOR_ENDPOINT}",
  "IdentityServer": {
    "Authority": "${IDENTITY_SERVER_URL}",
    "Audience": "urbanx-api"
  }
}
