@page "/products"

<PageTitle>Products - UrbanX Admin</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentLabel Typo="Typography.H2">Product Approval Queue</FluentLabel>

    <FluentCard>
        <FluentStack Orientation="Orientation.Horizontal" VerticalGap="8">
            <FluentSearch @bind-Value="_searchTerm" 
                          Placeholder="Search products..." 
                          @oninput="OnSearchInput"
                          Style="width: 300px;" />
            <FluentSelect TOption="string" @bind-Value="_filterStatus" Label="Filter by Status">
                <FluentOption Value="">All Status</FluentOption>
                <FluentOption Value="Pending">Pending Approval</FluentOption>
                <FluentOption Value="Approved">Approved</FluentOption>
                <FluentOption Value="Rejected">Rejected</FluentOption>
                <FluentOption Value="ChangesRequested">Changes Requested</FluentOption>
            </FluentSelect>
        </FluentStack>
    </FluentCard>

    <FluentDataGrid Items="@FilteredProducts" Pagination="@_pagination" Style="width: 100%;">
        <PropertyColumn Property="@(p => p.Name)" Title="Product" Sortable="true" />
        <PropertyColumn Property="@(p => p.TenantName)" Title="Tenant" Sortable="true" />
        <PropertyColumn Property="@(p => p.Category)" Title="Category" />
        <PropertyColumn Property="@(p => p.Price)" Title="Price" Format="C" Sortable="true" />
        <TemplateColumn Title="Status">
            @switch (context.Status)
            {
                case "Pending":
                    <FluentBadge Fill="somevalue" BackgroundColor="var(--warning)" Color="var(--neutral-foreground-on-accent)">@context.Status</FluentBadge>
                    break;
                case "Approved":
                    <FluentBadge Fill="somevalue" BackgroundColor="var(--success)" Color="var(--neutral-foreground-on-accent)">@context.Status</FluentBadge>
                    break;
                case "Rejected":
                    <FluentBadge Fill="somevalue" BackgroundColor="var(--error)" Color="var(--neutral-foreground-on-accent)">@context.Status</FluentBadge>
                    break;
                default:
                    <FluentBadge Appearance="Appearance.Neutral">@context.Status</FluentBadge>
                    break;
            }
        </TemplateColumn>
        <PropertyColumn Property="@(p => p.SubmittedAt)" Title="Submitted" Format="yyyy-MM-dd HH:mm" Sortable="true" />
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                @if (context.Status == "Pending")
                {
                    <FluentButton Appearance="Appearance.Lightweight" 

                                  OnClick="@(() => ApproveProduct(context))">
                        Approve
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Lightweight" 

                                  OnClick="@(() => RejectProduct(context))">
                        Reject
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Lightweight" 

                                  OnClick="@(() => RequestChanges(context))">
                        Request Edit
                    </FluentButton>
                }
                <FluentButton Appearance="Appearance.Lightweight" 

                              OnClick="@(() => DeleteProduct(context))">
                    Delete
                </FluentButton>
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>

    <FluentPaginator State="@_pagination" />
</FluentStack>

@code {
    private List<ProductModel> _products = new();
    private string _searchTerm = string.Empty;
    private string _filterStatus = string.Empty;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _products = new List<ProductModel>
        {
            new() { Id = Guid.NewGuid(), Name = "Smartphone X", TenantName = "Tech Store", Category = "Electronics", Price = 599.99m, Status = "Pending", SubmittedAt = DateTime.Now.AddHours(-2) },
            new() { Id = Guid.NewGuid(), Name = "Running Shoes", TenantName = "Sports World", Category = "Sports", Price = 89.99m, Status = "Approved", SubmittedAt = DateTime.Now.AddDays(-1) },
            new() { Id = Guid.NewGuid(), Name = "Summer Dress", TenantName = "Fashion Hub", Category = "Clothing", Price = 45.50m, Status = "Pending", SubmittedAt = DateTime.Now.AddHours(-5) },
            new() { Id = Guid.NewGuid(), Name = "LED Lamp", TenantName = "Home Decor", Category = "Home & Garden", Price = 29.99m, Status = "ChangesRequested", SubmittedAt = DateTime.Now.AddDays(-2) },
            new() { Id = Guid.NewGuid(), Name = "Fiction Novel", TenantName = "Book Corner", Category = "Books", Price = 15.99m, Status = "Rejected", SubmittedAt = DateTime.Now.AddDays(-3) },
        };
        await Task.CompletedTask;
    }

    private IQueryable<ProductModel> FilteredProducts
    {
        get
        {
            var filtered = _products.AsQueryable();
            if (!string.IsNullOrWhiteSpace(_searchTerm))
            {
                filtered = filtered.Where(p => 
                    p.Name.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    p.TenantName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrWhiteSpace(_filterStatus))
            {
                filtered = filtered.Where(p => p.Status == _filterStatus);
            }
            return filtered;
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchTerm = e.Value?.ToString() ?? string.Empty;
    }

    private async Task ApproveProduct(ProductModel product)
    {
        product.Status = "Approved";
        await Task.CompletedTask;
    }

    private async Task RejectProduct(ProductModel product)
    {
        product.Status = "Rejected";
        // TODO: Show dialog for rejection message
        await Task.CompletedTask;
    }

    private async Task RequestChanges(ProductModel product)
    {
        product.Status = "ChangesRequested";
        // TODO: Show dialog for change request message
        await Task.CompletedTask;
    }

    private async Task DeleteProduct(ProductModel product)
    {
        _products.Remove(product);
        await Task.CompletedTask;
    }

    public class ProductModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public string Status { get; set; } = "Pending";
        public DateTime SubmittedAt { get; set; }
    }
}
