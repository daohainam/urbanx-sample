# Environment Configuration Template for Production

# Copy this file to .env.production and fill in the actual values
# DO NOT commit .env.production to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
DATABASE_CONNECTION_STRING=Host=postgres;Database=urbanx;Username=postgres;Password=CHANGE_ME_STRONG_PASSWORD_32_CHARS;SslMode=Require

# =============================================================================
# IDENTITY SERVER CONFIGURATION
# =============================================================================
IDENTITY_SERVER_URL=https://identity.yourdomain.com
IDENTITY_SERVER_ISSUER_URI=https://identity.yourdomain.com

# =============================================================================
# CUSTOMER SPA CONFIGURATION
# =============================================================================
SPA_REDIRECT_URIS=https://app.yourdomain.com/callback
SPA_LOGOUT_URIS=https://app.yourdomain.com
SPA_CORS_ORIGINS=https://app.yourdomain.com

# =============================================================================
# MERCHANT PORTAL CONFIGURATION
# =============================================================================
MERCHANT_SPA_REDIRECT_URIS=https://merchant.yourdomain.com/callback
MERCHANT_SPA_LOGOUT_URIS=https://merchant.yourdomain.com
MERCHANT_SPA_CORS_ORIGINS=https://merchant.yourdomain.com

# =============================================================================
# API GATEWAY CONFIGURATION
# =============================================================================
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://merchant.yourdomain.com

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# =============================================================================
# KAFKA CONFIGURATION (if using external Kafka)
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# =============================================================================
# OPTIONAL: CLOUD-SPECIFIC CONFIGURATION
# =============================================================================

# Azure
# AZURE_KEY_VAULT_URI=https://your-keyvault.vault.azure.net/
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx

# AWS
# AWS_REGION=us-east-1
# AWS_SECRETS_MANAGER_PREFIX=urbanx/

# =============================================================================
# OPTIONAL: SMTP CONFIGURATION (for email notifications)
# =============================================================================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# OPTIONAL: REDIS CONFIGURATION (for caching)
# =============================================================================
# REDIS_CONNECTION_STRING=redis:6379,password=your-redis-password

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Minimum log level for production (Information, Warning, Error)
LOGGING_LEVEL=Information

# API Rate Limiting (requests per minute per user)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30
