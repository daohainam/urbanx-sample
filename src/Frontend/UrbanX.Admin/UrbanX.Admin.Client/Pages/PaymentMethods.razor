@page "/payment-methods"

<PageTitle>Payment Methods - UrbanX Admin</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentStack Orientation="Orientation.Horizontal">
        <FluentLabel Typo="Typography.H2">Payment Methods</FluentLabel>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="@ShowAddDialog">Add Method</FluentButton>
    </FluentStack>

    <FluentDataGrid Items="@_methods.AsQueryable()" Style="width: 100%;">
        <PropertyColumn Property="@(m => m.Name)" Title="Name" Sortable="true" />
        <PropertyColumn Property="@(m => m.Description)" Title="Description" />
        <PropertyColumn Property="@(m => m.Provider)" Title="Provider" />
        <PropertyColumn Property="@(m => m.TransactionFee)" Title="Fee" Format="P2" />
        <TemplateColumn Title="Status">
            @if (context.IsActive)
            {
                <FluentBadge Fill="somevalue" BackgroundColor="var(--success)" Color="var(--neutral-foreground-on-accent)">Active</FluentBadge>
            }
            else
            {
                <FluentBadge Fill="somevalue" BackgroundColor="var(--error)" Color="var(--neutral-foreground-on-accent)">Inactive</FluentBadge>
            }
        </TemplateColumn>
        <TemplateColumn Title="Actions">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => EditMethod(context))">Edit</FluentButton>
                <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => DeleteMethod(context))">Delete</FluentButton>
            </FluentStack>
        </TemplateColumn>
    </FluentDataGrid>
</FluentStack>

@code {
    private List<PaymentMethodModel> _methods = new();

    protected override async Task OnInitializedAsync()
    {
        _methods = new List<PaymentMethodModel>
        {
            new() { Name = "Credit Card", Description = "Visa, Mastercard, Amex", Provider = "Stripe", TransactionFee = 0.029m, IsActive = true },
            new() { Name = "PayPal", Description = "PayPal payment", Provider = "PayPal", TransactionFee = 0.034m, IsActive = true },
            new() { Name = "Bank Transfer", Description = "Direct bank transfer", Provider = "Internal", TransactionFee = 0.01m, IsActive = true },
        };
        await Task.CompletedTask;
    }

    private void ShowAddDialog() { /* TODO */ }
    private void EditMethod(PaymentMethodModel method) { /* TODO */ }
    private async Task DeleteMethod(PaymentMethodModel method) { _methods.Remove(method); await Task.CompletedTask; }

    public class PaymentMethodModel
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Provider { get; set; } = string.Empty;
        public decimal TransactionFee { get; set; }
        public bool IsActive { get; set; }
    }
}
