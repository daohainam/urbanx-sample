# Copy to `.env.development.local` (dev) or set in your prod build pipeline.
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Base URL for API calls. In dev this is proxied to the gateway by Vite (see vite.config.ts).
VITE_API_BASE_URL=/api

# Base URL for BFF endpoints (login/logout/user). Same-origin in production.
VITE_BFF_BASE_URL=/bff

# Build/release identifier. Surfaced to error reporting so events are tied to a release.
# In CI, set this to the commit SHA or semver tag.
VITE_APP_VERSION=dev

# Optional: Sentry DSN. Leave blank to disable client error reporting.
VITE_SENTRY_DSN=

# --- Legacy / pre-BFF only ---
# These are read while the in-browser OIDC flow is still active. Once the BFF migration
# (plan step C1) lands, they can be removed.
VITE_OIDC_AUTHORITY=http://localhost:5000
VITE_OIDC_CLIENT_ID=urbanx-spa
VITE_OIDC_SCOPES=openid profile email catalog.read orders.read orders.write
