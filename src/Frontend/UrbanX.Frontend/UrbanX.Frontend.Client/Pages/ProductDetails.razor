@page "/products/{ProductId:guid}"
@using UrbanX.Frontend.Client.Models
@using UrbanX.Frontend.Client.Services
@inject NavigationManager Navigation
@inject CartState Cart

<PageTitle>Product Details - UrbanX Shop</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentButton Appearance="Appearance.Lightweight" OnClick="GoBack">Back to products</FluentButton>

    @if (product is null)
    {
        <FluentMessageBar Intent="MessageIntent.Warning">
            Product not found.
        </FluentMessageBar>
    }
    else
    {
        <FluentGrid Spacing="3">
            <FluentGridItem xs="12" md="5">
                <FluentCard Style="width: 100%;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <div style="width: 100%; height: 320px; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" style="max-width: 100%; max-height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <FluentLabel>No Image</FluentLabel>
                            }
                        </div>

                        @if (imageUrls.Count > 1)
                        {
                            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="overflow-x: auto;">
                                @foreach (var url in imageUrls)
                                {
                                    <FluentButton Appearance="Appearance.Lightweight" OnClick="() => SelectImage(url)">
                                        <div style="width: 56px; height: 56px; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                            @if (!string.IsNullOrWhiteSpace(url))
                                            {
                                                <img src="@url" alt="@product.Name" style="max-width: 100%; max-height: 100%; object-fit: cover;" />
                                            }
                                        </div>
                                    </FluentButton>
                                }
                            </FluentStack>
                        }
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>

            <FluentGridItem xs="12" md="7">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                    <FluentLabel Typo="Typography.H2">@product.Name</FluentLabel>

                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                        <FluentLabel Typo="Typography.H4">@product.Price.ToString("C")</FluentLabel>
                        @if (!string.IsNullOrEmpty(product.Category))
                        {
                            <FluentBadge Appearance="Appearance.Accent">@product.Category</FluentBadge>
                        }
                    </FluentStack>

                    <FluentLabel Typo="Typography.Subject" Color="@(product.StockQuantity > 0 ? Color.Success : Color.Error)">
                        @(product.StockQuantity > 0 ? "In Stock" : "Out of Stock")
                    </FluentLabel>

                    @if (!string.IsNullOrWhiteSpace(product.Description))
                    {
                        <FluentCard>
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="6">
                                <FluentLabel Typo="Typography.H4">Description</FluentLabel>
                                <FluentLabel Typo="Typography.Body">@product.Description</FluentLabel>
                            </FluentStack>
                        </FluentCard>
                    }

                    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                        <FluentNumberField @bind-Value="quantity" Min="1" Step="1" Style="width: 140px;" />
                        <FluentButton Appearance="Appearance.Accent" Disabled="@(product.StockQuantity <= 0)" OnClick="AddToCart">
                            Add to cart
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Lightweight" OnClick="GoToCart">
                            View cart
                        </FluentButton>
                    </FluentStack>

                    @if (!string.IsNullOrWhiteSpace(statusMessage))
                    {
                        <FluentMessageBar Intent="MessageIntent.Success">@statusMessage</FluentMessageBar>
                    }
                </FluentStack>
            </FluentGridItem>
        </FluentGrid>
    }
</FluentStack>

@code {
    [Parameter] public Guid ProductId { get; set; }

    private Product? product;
    private int quantity = 1;
    private string statusMessage = string.Empty;
    private List<string> imageUrls = new();

    protected override void OnParametersSet()
    {
        product = GetSampleProducts().FirstOrDefault(p => p.Id == ProductId);

        if (product is not null)
        {
            imageUrls = new List<string>();

            if (!string.IsNullOrWhiteSpace(product.ImageUrl))
            {
                imageUrls.Add(product.ImageUrl);
            }

            imageUrls.AddRange(GetFallbackImageUrls(product));

            if (imageUrls.Count > 0)
            {
                product.ImageUrl = imageUrls[0];
            }

            quantity = 1;
            statusMessage = string.Empty;
        }
    }

    private void SelectImage(string url)
    {
        if (product is null || string.IsNullOrWhiteSpace(url))
        {
            return;
        }

        product.ImageUrl = url;
    }

    private void AddToCart()
    {
        if (product is null)
        {
            return;
        }

        Cart.Add(product, quantity);
        statusMessage = "Added to cart.";
    }

    private void GoToCart() => Navigation.NavigateTo("/cart");

    private void GoBack() => Navigation.NavigateTo("/products");

    private static List<Product> GetSampleProducts()
        => new()
        {
            new Product
            {
                Id = ProductsPageIds.Laptop,
                Name = "Laptop",
                Description = "Powerful laptop for work and play.",
                Price = 999.99m,
                Category = "Electronics",
                StockQuantity = 10,
                IsActive = true,
                CreatedAt = DateTime.Now,
                UpdatedAt = DateTime.Now,
                MerchantId = Guid.NewGuid(),
                ImageUrl = null
            },
            new Product
            {
                Id = ProductsPageIds.CoffeeMaker,
                Name = "Coffee Maker",
                Description = "Brew great coffee in minutes.",
                Price = 79.99m,
                Category = "Appliances",
                StockQuantity = 25,
                IsActive = true,
                CreatedAt = DateTime.Now,
                UpdatedAt = DateTime.Now,
                MerchantId = Guid.NewGuid(),
                ImageUrl = null
            }
        };

    private static IEnumerable<string> GetFallbackImageUrls(Product product)
    {
        // Placeholder list so the UI supports "images" now; can be replaced with real API data.
        // Keep empty strings out.
        var safeName = Uri.EscapeDataString(product.Name);
        return new[]
        {
            $"https://picsum.photos/seed/{safeName}-1/800/600",
            $"https://picsum.photos/seed/{safeName}-2/800/600",
            $"https://picsum.photos/seed/{safeName}-3/800/600"
        };
    }

    private static class ProductsPageIds
    {
        public static readonly Guid Laptop = Guid.Parse("11111111-1111-1111-1111-111111111111");
        public static readonly Guid CoffeeMaker = Guid.Parse("22222222-2222-2222-2222-222222222222");
    }
}
