{
  "realm": "urbanx",
  "enabled": true,
  "displayName": "UrbanX Realm",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>UrbanX</span></div>",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator with full access"
      },
      {
        "name": "merchant-editor",
        "description": "Merchant user who can edit products and categories"
      },
      {
        "name": "merchant-order-manager",
        "description": "Merchant user who can manage orders"
      },
      {
        "name": "buyer",
        "description": "Customer/buyer who can browse and purchase products"
      }
    ]
  },
  "clients": [
    {
      "clientId": "urbanx-spa",
      "name": "UrbanX Frontend SPA",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "https://localhost:5173/*",
        "http://localhost:7001/*",
        "https://localhost:7002/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "https://localhost:5173",
        "http://localhost:7001",
        "https://localhost:7002"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "urbanx-merchant-spa",
      "name": "UrbanX Merchant Portal",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:5174/*",
        "https://localhost:5174/*"
      ],
      "webOrigins": [
        "http://localhost:5174",
        "https://localhost:5174"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "admin@urbanx.com",
      "email": "admin@urbanx.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ],
      "attributes": {}
    },
    {
      "username": "merchant1@urbanx.com",
      "email": "merchant1@urbanx.com",
      "firstName": "Merchant",
      "lastName": "One",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Merchant123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "merchant-editor",
        "merchant-order-manager"
      ],
      "attributes": {
        "merchantId": ["merchant-001"]
      }
    },
    {
      "username": "merchant2@urbanx.com",
      "email": "merchant2@urbanx.com",
      "firstName": "Merchant",
      "lastName": "Two",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Merchant123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "merchant-editor"
      ],
      "attributes": {
        "merchantId": ["merchant-002"]
      }
    },
    {
      "username": "buyer1@urbanx.com",
      "email": "buyer1@urbanx.com",
      "firstName": "John",
      "lastName": "Buyer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Buyer123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "buyer"
      ],
      "attributes": {}
    },
    {
      "username": "buyer2@urbanx.com",
      "email": "buyer2@urbanx.com",
      "firstName": "Jane",
      "lastName": "Customer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Buyer123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "buyer"
      ],
      "attributes": {}
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "description": "OpenID Connect scope for add user roles to the access token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}
