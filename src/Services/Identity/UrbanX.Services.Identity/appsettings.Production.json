{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Duende": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "IssuerUri": "${IDENTITY_SERVER_ISSUER_URI}",
    "Clients": {
      "UrbanXSpa": {
        "RedirectUris": "${SPA_REDIRECT_URIS}",
        "PostLogoutRedirectUris": "${SPA_LOGOUT_URIS}",
        "AllowedCorsOrigins": "${SPA_CORS_ORIGINS}"
      },
      "UrbanXMerchantSpa": {
        "RedirectUris": "${MERCHANT_SPA_REDIRECT_URIS}",
        "PostLogoutRedirectUris": "${MERCHANT_SPA_LOGOUT_URIS}",
        "AllowedCorsOrigins": "${MERCHANT_SPA_CORS_ORIGINS}"
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "UrbanX.Identity.Service"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_COLLECTOR_ENDPOINT}"
}
