@page
@model UrbanX.Services.Identity.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Sign Out";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UrbanX – @ViewData["Title"]</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .card { background: #fff; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,.12); padding: 2rem; width: 100%; max-width: 380px; text-align: center; }
        h1 { margin: 0 0 1rem; font-size: 1.5rem; color: #1a1a1a; }
        p { color: #555; margin-bottom: 1.5rem; }
        .btn-group { display: flex; gap: .75rem; justify-content: center; }
        button { padding: .625rem 1.5rem; border-radius: 4px; font-size: 1rem; cursor: pointer; border: none; }
        .btn-danger { background: #c53030; color: #fff; }
        .btn-danger:hover { background: #9b2c2c; }
        .btn-secondary { background: #eee; color: #333; }
        .btn-secondary:hover { background: #ddd; }
    </style>
</head>
<body>
<div class="card">
    <h1>Sign Out</h1>

    @if (Model.ShowLogoutPrompt)
    {
        <p>Are you sure you want to sign out?</p>
        <form method="post">
            <input type="hidden" asp-for="LogoutId" />
            <div class="btn-group">
                <button type="submit" class="btn-danger">Yes, sign me out</button>
                <a href="/" class="btn btn-secondary" style="text-decoration:none;padding:.625rem 1.5rem;border-radius:4px;background:#eee;color:#333;">Cancel</a>
            </div>
        </form>
    }
    else
    {
        <p>You have been signed out.</p>
        @if (Model.PostLogoutRedirectUri != null)
        {
            <p><a href="@Model.PostLogoutRedirectUri">Return to application</a></p>
        }
    }
</div>
</body>
</html>
