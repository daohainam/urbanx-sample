@page "/orders"
@attribute [Authorize(Roles = "admin")]

<PageTitle>Orders - UrbanX Admin</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentLabel Typo="Typography.H2">Orders</FluentLabel>

    <FluentCard>
        <FluentStack Orientation="Orientation.Horizontal" VerticalGap="8">
            <FluentSearch @bind-Value="_searchTerm" Placeholder="Search orders..." @oninput="OnSearchInput" Style="width: 300px;" />
            <FluentSelect TOption="string" @bind-Value="_filterStatus" Label="Status">
                <FluentOption Value="">All</FluentOption>
                <FluentOption Value="Pending">Pending</FluentOption>
                <FluentOption Value="Accepted">Accepted</FluentOption>
                <FluentOption Value="InFulfillment">In Fulfillment</FluentOption>
                <FluentOption Value="Sending">Sending</FluentOption>
                <FluentOption Value="Delivered">Delivered</FluentOption>
                <FluentOption Value="Cancelled">Cancelled</FluentOption>
            </FluentSelect>
        </FluentStack>
    </FluentCard>

    <FluentDataGrid Items="@FilteredOrders" Pagination="@_pagination" Style="width: 100%;">
        <PropertyColumn Property="@(o => o.OrderNumber)" Title="Order #" Sortable="true" />
        <PropertyColumn Property="@(o => o.CustomerName)" Title="Customer" Sortable="true" />
        <PropertyColumn Property="@(o => o.TenantName)" Title="Tenant" />
        <PropertyColumn Property="@(o => o.TotalAmount)" Title="Amount" Format="C" Sortable="true" />
        <TemplateColumn Title="Status">
            @{
                var statusBadge = GetStatusBadge(context.Status);
            }
            <FluentBadge Fill="somevalue" BackgroundColor="@statusBadge.Color" Color="var(--neutral-foreground-on-accent)">
                @context.Status
            </FluentBadge>
        </TemplateColumn>
        <PropertyColumn Property="@(o => o.CreatedAt)" Title="Date" Format="yyyy-MM-dd HH:mm" Sortable="true" />
        <TemplateColumn Title="Actions">
            <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => ViewOrder(context))">View Details</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>

    <FluentPaginator State="@_pagination" />
</FluentStack>

@if (_selectedOrder != null)
{
    <FluentDialog @bind-Hidden="@_dialogHidden" Modal="true" TrapFocus="true" Style="min-width: 600px;">
        <FluentDialogHeader>
            <FluentLabel Typo="Typography.H4">Order Details - @_selectedOrder.OrderNumber</FluentLabel>
        </FluentDialogHeader>
        <FluentDialogBody>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentLabel Typo="Typography.H6">Customer Information</FluentLabel>
                        <FluentLabel><strong>Name:</strong> @_selectedOrder.CustomerName</FluentLabel>
                        <FluentLabel><strong>Email:</strong> @_selectedOrder.CustomerEmail</FluentLabel>
                        <FluentLabel><strong>Phone:</strong> @_selectedOrder.CustomerPhone</FluentLabel>
                        <FluentLabel><strong>Shipping Address:</strong> @_selectedOrder.ShippingAddress</FluentLabel>
                    </FluentStack>
                </FluentCard>

                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentLabel Typo="Typography.H6">Order Information</FluentLabel>
                        <FluentLabel><strong>Tenant:</strong> @_selectedOrder.TenantName</FluentLabel>
                        <FluentLabel><strong>Order Date:</strong> @_selectedOrder.CreatedAt.ToString("yyyy-MM-dd HH:mm")</FluentLabel>
                        <FluentLabel><strong>Total Amount:</strong> @_selectedOrder.TotalAmount.ToString("C")</FluentLabel>
                        <FluentLabel><strong>Payment Method:</strong> @_selectedOrder.PaymentMethod</FluentLabel>
                        <FluentLabel>
                            <strong>Status:</strong> 
                            @{
                                var badge = GetStatusBadge(_selectedOrder.Status);
                            }
                            <FluentBadge Fill="somevalue" BackgroundColor="@badge.Color" Color="var(--neutral-foreground-on-accent)">
                                @_selectedOrder.Status
                            </FluentBadge>
                        </FluentLabel>
                    </FluentStack>
                </FluentCard>

                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentLabel Typo="Typography.H6">Order Items</FluentLabel>
                        <FluentDataGrid Items="@_selectedOrder.Items.AsQueryable()" GridTemplateColumns="2fr 1fr 1fr 1fr">
                            <PropertyColumn Property="@(i => i.ProductName)" Title="Product" />
                            <PropertyColumn Property="@(i => i.Quantity)" Title="Quantity" />
                            <PropertyColumn Property="@(i => i.UnitPrice)" Title="Unit Price" Format="C" />
                            <PropertyColumn Property="@(i => i.TotalPrice)" Title="Total" Format="C" />
                        </FluentDataGrid>
                    </FluentStack>
                </FluentCard>

                <FluentCard>
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentLabel Typo="Typography.H6">Update Order Status</FluentLabel>
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                            @if (_selectedOrder.Status == "Pending")
                            {
                                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => UpdateOrderStatus("Accepted"))">
                                    Accept Order
                                </FluentButton>
                                <FluentButton Appearance="Appearance.Lightweight" OnClick="@(() => UpdateOrderStatus("Cancelled"))">
                                    Cancel Order
                                </FluentButton>
                            }
                            @if (_selectedOrder.Status == "Accepted")
                            {
                                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => UpdateOrderStatus("InFulfillment"))">
                                    Start Fulfillment
                                </FluentButton>
                            }
                            @if (_selectedOrder.Status == "InFulfillment")
                            {
                                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => UpdateOrderStatus("Sending"))">
                                    Mark as Sending
                                </FluentButton>
                            }
                            @if (_selectedOrder.Status == "Sending")
                            {
                                <FluentButton Appearance="Appearance.Accent" OnClick="@(() => UpdateOrderStatus("Delivered"))">
                                    Mark as Delivered
                                </FluentButton>
                            }
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            </FluentStack>
        </FluentDialogBody>
        <FluentDialogFooter>
            <FluentButton Appearance="Appearance.Lightweight" OnClick="@CloseDialog">Close</FluentButton>
        </FluentDialogFooter>
    </FluentDialog>
}

@code {
    private List<OrderModel> _orders = new();
    private string _searchTerm = string.Empty;
    private string _filterStatus = string.Empty;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 10 };
    private OrderModel? _selectedOrder;
    private bool _dialogHidden = true;

    protected override async Task OnInitializedAsync()
    {
        _orders = new List<OrderModel>
        {
            new() 
            { 
                OrderNumber = "ORD-2026-001", 
                CustomerName = "John Doe", 
                CustomerEmail = "john.doe@email.com",
                CustomerPhone = "+1-555-0101",
                ShippingAddress = "123 Main St, New York, NY 10001",
                TenantName = "Tech Store", 
                TotalAmount = 599.99m, 
                Status = "Pending", 
                PaymentMethod = "Credit Card",
                CreatedAt = DateTime.Now.AddHours(-2),
                Items = new List<OrderItemModel>
                {
                    new() { ProductName = "Smartphone X", Quantity = 1, UnitPrice = 599.99m, TotalPrice = 599.99m }
                }
            },
            new() 
            { 
                OrderNumber = "ORD-2026-002", 
                CustomerName = "Jane Smith", 
                CustomerEmail = "jane.smith@email.com",
                CustomerPhone = "+1-555-0102",
                ShippingAddress = "456 Oak Ave, Los Angeles, CA 90001",
                TenantName = "Fashion Hub", 
                TotalAmount = 125.50m, 
                Status = "Accepted", 
                PaymentMethod = "PayPal",
                CreatedAt = DateTime.Now.AddHours(-5),
                Items = new List<OrderItemModel>
                {
                    new() { ProductName = "Summer Dress", Quantity = 2, UnitPrice = 45.50m, TotalPrice = 91.00m },
                    new() { ProductName = "Handbag", Quantity = 1, UnitPrice = 34.50m, TotalPrice = 34.50m }
                }
            },
            new() 
            { 
                OrderNumber = "ORD-2026-003", 
                CustomerName = "Bob Johnson", 
                CustomerEmail = "bob.johnson@email.com",
                CustomerPhone = "+1-555-0103",
                ShippingAddress = "789 Pine Rd, Chicago, IL 60601",
                TenantName = "Book Corner", 
                TotalAmount = 45.99m, 
                Status = "Delivered", 
                PaymentMethod = "Credit Card",
                CreatedAt = DateTime.Now.AddDays(-1),
                Items = new List<OrderItemModel>
                {
                    new() { ProductName = "Fiction Novel", Quantity = 3, UnitPrice = 15.33m, TotalPrice = 45.99m }
                }
            },
        };
        await Task.CompletedTask;
    }

    private IQueryable<OrderModel> FilteredOrders
    {
        get
        {
            var filtered = _orders.AsQueryable();
            if (!string.IsNullOrWhiteSpace(_searchTerm))
                filtered = filtered.Where(o => o.OrderNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) || o.CustomerName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(_filterStatus))
                filtered = filtered.Where(o => o.Status == _filterStatus);
            return filtered;
        }
    }

    private void OnSearchInput(ChangeEventArgs e) => _searchTerm = e.Value?.ToString() ?? string.Empty;
    
    private void ViewOrder(OrderModel order)
    {
        _selectedOrder = order;
        _dialogHidden = false;
    }

    private void CloseDialog()
    {
        _dialogHidden = true;
        _selectedOrder = null;
    }

    private void UpdateOrderStatus(string newStatus)
    {
        if (_selectedOrder != null)
        {
            _selectedOrder.Status = newStatus;
            StateHasChanged();
        }
    }

    private (string Color, string Label) GetStatusBadge(string status)
    {
        return status switch
        {
            "Pending" => ("var(--warning)", "Pending"),
            "Accepted" => ("var(--info)", "Accepted"),
            "InFulfillment" => ("var(--info)", "In Fulfillment"),
            "Sending" => ("var(--accent)", "Sending"),
            "Delivered" => ("var(--success)", "Delivered"),
            "Cancelled" => ("var(--error)", "Cancelled"),
            _ => ("var(--neutral)", status)
        };
    }

    public class OrderModel
    {
        public string OrderNumber { get; set; } = string.Empty;
        public string CustomerName { get; set; } = string.Empty;
        public string CustomerEmail { get; set; } = string.Empty;
        public string CustomerPhone { get; set; } = string.Empty;
        public string ShippingAddress { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public decimal TotalAmount { get; set; }
        public string Status { get; set; } = string.Empty;
        public string PaymentMethod { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public List<OrderItemModel> Items { get; set; } = new();
    }

    public class OrderItemModel
    {
        public string ProductName { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal TotalPrice { get; set; }
    }
}
