{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimit": {
    "RequestsPerMinute": 100
  },
  "ReverseProxy": {
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://catalog-service:8080"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://order-service:8080"
          }
        }
      },
      "merchant-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://merchant-service:8080"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://payment-service:8080"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity-service:8080"
          }
        }
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "UrbanX.Gateway"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "",
  "IdentityServer": {
    "Authority": "",
    "Audience": "urbanx-api"
  }
}
