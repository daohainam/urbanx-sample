@page "/cart"
@using UrbanX.Frontend.Client.Services
@inject NavigationManager Navigation
@inject CartState CartStore

<PageTitle>Shopping Cart - UrbanX Shop</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <FluentLabel Typo="Typography.H2">Shopping Cart</FluentLabel>

    @if (CartStore.Items.Count == 0)
    {
        <FluentMessageBar Intent="MessageIntent.Info">
            Your cart is empty. <a href="/products">Browse products</a>
        </FluentMessageBar>
    }           
    else
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
                @foreach (var item in CartStore.Items)
                {
                    var qty = GetQty(item.Product.Id);

                    <div style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
                        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">@item.Product.Name</FluentLabel>
                            <FluentLabel Typo="Typography.Body">@item.Product.Price.ToString("C")</FluentLabel>
                        </FluentStack>

                        <div style="display:flex; align-items:center; gap:8px;">
                            <FluentNumberField @bind-Value="qty" Min="1" Step="1" Style="width: 120px;" />
                            <FluentButton Appearance="Appearance.Lightweight" OnClick="() => UpdateQty(item.Product.Id, qty)">Update</FluentButton>

                            <FluentLabel Typo="Typography.Body" Style="min-width: 90px; text-align: right;">
                                @((item.Product.Price * item.Quantity).ToString("C"))
                            </FluentLabel>
                            <FluentButton Appearance="Appearance.Lightweight" OnClick="() => Remove(item.Product.Id)">Remove</FluentButton>
                        </div>
                    </div>
                }

                <FluentDivider />

                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <FluentLabel Typo="Typography.H4">Total</FluentLabel>
                    <FluentLabel Typo="Typography.H4">@CartStore.TotalPrice.ToString("C")</FluentLabel>
                </div>

                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="Clear">Clear cart</FluentButton>
                    <FluentButton Appearance="Appearance.Accent" Disabled="true">Checkout (todo)</FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    private readonly Dictionary<Guid, int> _qty = new();

    protected override void OnInitialized()
    {
        CartStore.Changed += OnCartChanged;
    }

    public void Dispose()
    {
        CartStore.Changed -= OnCartChanged;
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    private int GetQty(Guid productId)
    {
        if (_qty.TryGetValue(productId, out var q))
        {
            return q;
        }

        var current = CartStore.Items.First(i => i.Product.Id == productId).Quantity;
        _qty[productId] = current;
        return current;
    }

    private void UpdateQty(Guid productId, int qty) => CartStore.SetQuantity(productId, qty);

    private void Remove(Guid productId)
    {
        _qty.Remove(productId);
        CartStore.Remove(productId);
    }

    private void Clear()
    {
        _qty.Clear();
        CartStore.Clear();
    }
}
